{
  "name": "kabir-ke-dohe-api",
  "version": "1.0.0",
  "description": "An API for fetching and filtering Kabir's dohas, built with Next.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "prebuild": "npm run build-data",
    "build": "next build",
    "postbuild": "next-sitemap",
    "build:data": "node ./scripts/build-data.mjs",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "preindexnow": "next-sitemap",
    "indexnow": "node ./scripts/indexnow.mjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "Kabir",
    "dohe",
    "Next.js",
    "API",
    "Vercel"
  ],
  "author": "Vijay Hardaha",
  "license": "MIT",
  "dependencies": {
    "@next/third-parties": "^16.1.6",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "latinize": "^2.0.0",
    "next": "^16.1.6",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "slugify": "^1.6.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@next/eslint-plugin-next": "^15.5.12",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.5.12",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.3.0",
    "google-auth-library": "^10.5.0",
    "google-spreadsheet": "^5.2.0",
    "next-sitemap": "^4.2.3",
    "ora": "^9.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prop-types": "^15.8.1",
    "react-icons": "^5.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "xml2js": "^0.6.2"
  }
}
