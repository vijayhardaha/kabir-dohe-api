{
  "name": "kabir-ke-dohe-api",
  "version": "1.0.0",
  "description": "An API for fetching and filtering Kabir's dohas, built with Next.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "fix": "next lint --fix",
