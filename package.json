    "google-spreadsheet": "^4.1.4",
    "latinize": "^2.0.0",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.9",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.27.0",
    "@next/eslint-plugin-next": "^15.3.2",
    "@next/third-parties": "^15.3.2",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "22.15.19",
