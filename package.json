{
  "name": "kabir-ke-dohe-api",
  "version": "1.0.0",
  "description": "An API for fetching and filtering Kabir's dohas, built with Next.js",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "start": "next start",
    "build": "next build",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx,.mjs,.cjs .",
    "lint:fix": "eslint --fix --ext .ts,.tsx,.js,.jsx,.mjs,.cjs .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "postbuild": "next-sitemap",
    "preindexnow": "bun run build && next-sitemap",
    "indexnow": "bun run scripts/indexnow.ts",
    "build:data": "bun run scripts/coupletscsv.ts",
    "sync": "bun --env-file=.env.local scripts/sync.ts",
    "sync:prod": "bun --env-file=.env.production scripts/sync.ts",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "keywords": [
    "Kabir",
    "dohe",
    "Next.js",
    "API",
    "Vercel"
  ],
  "author": "Vijay Hardaha",
  "license": "MIT",
  "dependencies": {
    "@next/third-parties": "^16.2.1",
    "@supabase/supabase-js": "^2.100.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "latinize": "^2.0.0",
    "next": "^16.2.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "slugify": "^1.6.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.3",
    "@next/eslint-plugin-next": "^15.5.13",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/latinize": "^0.2.18",
    "@types/node": "25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vijayhardaha/dev-config": "^1.0.5",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.5.13",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "google-auth-library": "^10.6.2",
    "google-spreadsheet": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "next-sitemap": "^4.2.3",
    "ollama": "^0.6.3",
    "ora": "^9.3.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2",
    "xml2js": "^0.6.2"
  }
}
